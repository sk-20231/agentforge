# Copy to .env and set your values. Never commit .env.
# OPENAI_API_KEY is read by the OpenAI client by default.

# Chat model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Embedding model (default: text-embedding-3-small)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: custom API base URL (e.g. proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Paths (defaults: memory, agent_logs.jsonl, corpus.json)
# AGENT_MEMORY_DIR=memory
# AGENT_LOG_FILE=agent_logs.jsonl
# AGENT_CORPUS_FILE=corpus.json
